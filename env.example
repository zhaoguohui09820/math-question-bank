# AI service configuration.
# Copy this file to `.env` and fill in your own API key.

AI_API_KEY=your_api_key_here
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL_NAME=qwen-vl-plus

# Optional: use a separate model for solution generation.
# If unset, the app falls back to qwen3.6-flash in the current code.
AI_SOLVER_MODEL_NAME=qwen3.6-flash

# Optional fallback OCR prompt. If `ocr_prompt.txt` exists, it takes precedence.
# Use `\n` for line breaks when defining a multi-line prompt in .env.
AI_OCR_PROMPT=请识别这张图片中的数学题，并严格按照 LaTeX 格式输出。
